rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to validate string length
    function isValidtext(text) {
      return text is string && text.size() > 0 && text.size() < 100;
    }

    // ORGANIZATIONS
    // Allow creating and reading organizations. 
    // WARNING: Currently, password validation is client-side, so read access allows viewing passwords.
    match /organizations/{orgId} {
      allow read: if true;
      allow create: if isValidtext(request.resource.data.name) 
                   && isValidtext(request.resource.data.password);
      // Optional: Prevent updating/deleting to preserve history
      allow update, delete: if false; 
    }

    // MEMBERS
    match /members/{memberId} {
      allow read: if true;
      allow create: if request.resource.data.organizationId is string;
      allow update: if true;
      allow delete: if false; 
    }

    // PLAYERS
    match /players/{playerId} {
      allow read: if true;
      allow create: if request.resource.data.organizationId is string;
      allow update: if true; 
      allow delete: if true; 
    }

    // POKER STATE
    match /pokerState/{orgId} {
      allow read: if true;
      allow write: if true; 
    }
  }
}
